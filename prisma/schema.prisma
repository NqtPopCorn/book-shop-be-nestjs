generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  firstName String?    @map("first_name")
  lastName  String?    @map("last_name")
  role      Role       @default(CUSTOMER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  orders    Order[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]

  @@map("categories")
}

model Batch {
  id        Int         @id @default(autoincrement())
  code      String      @unique
  quantity  Int         @default(0)
  variantId Int         @map("variant_id")
  variant   BookVariant @relation(fields: [variantId], references: [id])
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([variantId])
  @@map("batches")
}

model Book {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?
  authors      Json?
  categoryId   Int?          @map("category_id")
  publisher    String?
  translators  Json?
  provider     String?
  publishYear  Int?          @map("publish_year")
  language     String?
  category     Category?     @relation(fields: [categoryId], references: [id])
  variants     BookVariant[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([categoryId])
  @@map("books")
}

model BookVariant {
  id           Int         @id @default(autoincrement())
  bookId       Int         @map("book_id")
  sku          String      @unique
  isbn         String?     @unique
  format       String?     // e.g., "Bìa cứng", "Bìa mềm"
  imageUrl     String?     @map("image_url")
  listPrice    Decimal     @db.Decimal(12, 2) @map("list_price")
  sellingPrice Decimal     @db.Decimal(12, 2) @map("selling_price")
  stock        Int         @default(0)
  weight       Int?
  dimensions   String?
  pages        Int?
  book         Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  batches      Batch[]
  orderItems   OrderItem[]

  @@index([bookId])
  @@map("book_variants")
}

model Promotion {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  percentage Int?
  conditions Json?
  actions    Json?
  maxUses    Int?      @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  active     Boolean   @default(true)
  orders     Order[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("promotions")
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  promotionId Int?        @map("promotion_id")
  status      OrderStatus @default(PENDING)
  total       Decimal     @db.Decimal(12, 2)
  user        User        @relation(fields: [userId], references: [id])
  promotion   Promotion?  @relation(fields: [promotionId], references: [id])
  items       OrderItem[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([promotionId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

model OrderItem {
  id        Int         @id @default(autoincrement())
  orderId   Int         @map("order_id")
  variantId Int         @map("variant_id")
  quantity  Int
  unitPrice Decimal     @map("unit_price") @db.Decimal(12, 2)
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   BookVariant @relation(fields: [variantId], references: [id])

  @@unique([orderId, variantId])
  @@map("order_items")
}
